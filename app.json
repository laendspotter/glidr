{
  "expo": {
    "name": "glidr",
    "slug": "glidr",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "glidr",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0E14"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.laendspotter.glidr",
      "usesAppleSignIn": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "wird gebraucht um deine flüge live zu tracken",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "wird gebraucht um deinen flug auch im hintergrund zu tracken",
        "UIBackgroundModes": [
          "location"
        ]
      }
    },
    "android": {
      "package": "com.laendspotter.glidr",
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0E14"
      },
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "ACCESS_COARSE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-location",
      "expo-apple-authentication",
      [
        "expo-notifications",
        {
          "icon": "./assets/notification-icon.png",
          "color": "#EC0016"
        }
      ],
      "expo-asset"
    ],
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
